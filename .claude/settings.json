      "Bash(curl -s --max-time 30 http://localhost:3000)",
      "Bash(lsof -ti:3000)",
      "Bash(curl -s --max-time 60 http://localhost:3000)",
      "Bash(echo \"exit: $?\")",
      "Bash(osascript)",
      "WebFetch(domain:docs.google.com)",
      "Bash(git init *)",
      "Bash(git remote *)"
    ]
  }
